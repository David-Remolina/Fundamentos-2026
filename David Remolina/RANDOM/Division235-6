#include <iostream>

using namespace std;

int main() {

    int n, i;
    cout << "Ingrese un Entero: ";
    cin >> n;
    i = 1;

    while (i <= n) 
    {
        if (i % 2 == 0) 
        {
            cout << i << ": " << "Divisible Entre 2" << endl;

            if (i % 3 == 0) 
            {
                cout << " y 3" << endl;

                if (i % 5 == 0) 
                {
                    cout << " y 5" << endl;
                }
            } 
            else 
            {
                if (i % 5 == 0) 
                {
                    cout << " y 5." << endl;
                }
            }
        } 
        else 
        {
            if (i % 3 == 0) 
            {
                cout << i << ": " << "Divisible entre 3" << endl;
                if (i % 5 == 0) 
                {
                    cout << " y 5." << endl;
                }

            } 
            else 
            {
                if (i % 5 == 0) 
                {
                    cout << i << ": " << "Divisible entre 5" << endl;
                } 
                else 
                {
                    cout << i << ": " << endl;
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

